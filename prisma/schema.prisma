generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  createdAt      DateTime      @default(now())
  explanations   Explanation[]
}

model Explanation {
  id        String   @id @default(uuid())
  topic     String
  answer    String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
