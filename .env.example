DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
# Optional override: disable | require | verify-full
# - disable: for local Postgres without SSL
# - require: for TLS with self-signed/internal CA
# - verify-full: strict CA/hostname verification
# If omitted, localhost => disable, others => inferred from DB_SSL_REJECT_UNAUTHORIZED.
DB_SSL_MODE=verify-full
# Legacy toggle when DB_SSL_MODE is omitted:
# true  => strict TLS (verify-full)
# false => self-signed compatible TLS (require + libpq compat)
DB_SSL_REJECT_UNAUTHORIZED=true
JWT_SECRET="replace-with-a-long-random-secret"
LLMAPI_KEY="replace-with-your-llmapi-key"
LLMAPI_MODEL="qwen-flash"
CORS_ORIGIN="http://localhost:4200,https://your-frontend-domain.vercel.app"
PORT=3000
