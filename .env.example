DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"
# Set to false only if your Postgres provider uses a self-signed certificate chain.
DB_SSL_REJECT_UNAUTHORIZED=true
JWT_SECRET="replace-with-a-long-random-secret"
LLMAPI_KEY="replace-with-your-llmapi-key"
LLMAPI_MODEL="qwen-flash"
CORS_ORIGIN="http://localhost:4200,https://your-frontend-domain.vercel.app"
PORT=3000
